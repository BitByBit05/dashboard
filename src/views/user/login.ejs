<%- include('../partials/header') %>

<div class="auth-container">
  <div class="auth-card">
    <div class="auth-header">
      <h2>Welcome Back</h2>
      <p class="auth-subtitle">Log in to manage your BookShelf library</p>
    </div>

    <!-- Alert Box -->
    <div id="alertBox" class="alert-box hidden"></div>

    <form id="loginForm" novalidate>
      <div class="form-group">
        <label for="email">Email Address</label>
        <div class="input-wrapper">
          <input
            id="email"
            name="email"
            type="email"
            required
            placeholder="name@example.com"
            autocomplete="email"
          />
        </div>
      </div>

      <div class="form-group">
        <label for="password">Password</label>
        <div class="input-wrapper">
          <input
            id="password"
            name="password"
            type="password"
            required
            placeholder="Enter your password"
            autocomplete="current-password"
          />
        </div>
      </div>

      <button type="submit" id="submitBtn" class="btn btn-primary btn-block">
        <span class="btn-text">Log In</span>
        <div class="spinner hidden"></div>
      </button>

      <div class="auth-footer-text">
        Don't have an account? <a href="/users/register">Register here</a>
      </div>
    </form>
  </div>
</div>

<style>
  /* Premium Login Styling */
  .auth-container {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 70vh;
    padding: 1.5rem 0;
  }

  .auth-card {
    background: #ffffff;
    border-radius: 12px;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.05), 0 5px 10px rgba(0, 0, 0, 0.02);
    border: 1px solid #e2e8f0;
    width: 100%;
    max-width: 440px;
    padding: 2.5rem;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .auth-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 15px 30px rgba(47, 93, 159, 0.08);
  }

  .auth-header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .auth-header h2 {
    font-size: 1.75rem;
    font-weight: 800;
    color: #1a202c;
    margin-bottom: 0.5rem;
  }

  .auth-subtitle {
    color: #718096;
    font-size: 0.9rem;
  }

  /* Form and Input styling overrides for premium feel */
  .form-group {
    margin-bottom: 1.25rem;
  }

  .form-group label {
    font-weight: 600;
    color: #4a5568;
    margin-bottom: 0.4rem;
    font-size: 0.85rem;
  }

  .input-wrapper input {
    border-radius: 8px;
    border: 1.5px solid #cbd5e0;
    padding: 0.75rem 0.9rem;
    font-size: 0.95rem;
    transition: all 0.2s ease;
    background: #f8fafc;
  }

  .input-wrapper input:focus {
    border-color: var(--accent);
    background: #ffffff;
    box-shadow: 0 0 0 3px rgba(47, 93, 159, 0.15);
  }

  /* Block button and loading */
  .btn-block {
    width: 100%;
    padding: 0.8rem;
    font-size: 1rem;
    font-weight: 700;
    border-radius: 8px;
    margin-top: 1.5rem;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.5rem;
    transition: all 0.2s ease;
  }

  .btn-block:active {
    transform: scale(0.98);
  }

  .auth-footer-text {
    text-align: center;
    margin-top: 1.5rem;
    font-size: 0.875rem;
    color: #718096;
  }

  .auth-footer-text a {
    color: var(--accent);
    text-decoration: none;
    font-weight: 600;
  }

  .auth-footer-text a:hover {
    text-decoration: underline;
  }

  /* Alert Box styling */
  .alert-box {
    padding: 0.85rem 1rem;
    border-radius: 8px;
    font-size: 0.875rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
    transition: all 0.3s ease;
  }

  .alert-box.success {
    background-color: #f0fdf4;
    border: 1px solid #bbf7d0;
    color: #15803d;
  }

  .alert-box.error {
    background-color: #fef2f2;
    border: 1px solid #fecaca;
    color: #b91c1c;
  }

  .hidden {
    display: none !important;
  }

  /* Spinner */
  .spinner {
    width: 20px;
    height: 20px;
    border: 3px solid rgba(255, 255, 255, 0.3);
    border-radius: 50%;
    border-top-color: #ffffff;
    animation: spin 0.8s ease-in-out infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('loginForm');
    const emailInput = document.getElementById('email');
    const passwordInput = document.getElementById('password');
    const submitBtn = document.getElementById('submitBtn');
    const alertBox = document.getElementById('alertBox');
    const spinner = submitBtn.querySelector('.spinner');
    const btnText = submitBtn.querySelector('.btn-text');

    function showAlert(message, type = 'error') {
      alertBox.textContent = message;
      alertBox.className = `alert-box ${type}`;
      alertBox.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }

    function hideAlert() {
      alertBox.className = 'alert-box hidden';
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      hideAlert();

      const email = emailInput.value.trim();
      const password = passwordInput.value;

      // Front-end validations
      if (!email || !password) {
        showAlert('Please enter your email and password.');
        return;
      }

      // Show loader
      submitBtn.disabled = true;
      spinner.classList.remove('hidden');
      btnText.textContent = 'Logging in...';

      try {
        const response = await fetch('/users/login', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({ email, password }),
        });

        const data = await response.json();

        if (!response.ok) {
          throw new Error(data.error || data.message || 'Login failed');
        }

        showAlert('Logged in successfully! Redirecting...', 'success');
        
        // Dynamic success redirect
        setTimeout(() => {
          window.location.href = '/books';
        }, 1200);

      } catch (err) {
        showAlert(err.message || 'Something went wrong. Please try again.');
        submitBtn.disabled = false;
        spinner.classList.add('hidden');
        btnText.textContent = 'Log In';
      }
    });
  });
</script>

<%- include('../partials/footer') %>
